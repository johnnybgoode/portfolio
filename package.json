{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @portfolio/web dev",
    "build": "pnpm --filter @portfolio/web build",
    "check-types": "pnpm -r check-types",
    "lint": "biome check --diagnostic-level=warn --write",
    "format": "biome format --write",
    "fml": "biome format . --write; biome check . --write",
    "precommit": "biome check --staged",
    "test": "pnpm --filter @portfolio/web test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^25.0.10",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.32.0"
}
