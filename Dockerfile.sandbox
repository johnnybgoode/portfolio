# docker build -t portfolio:latest -f Dockerfile.sandbox .
# GIT_USER=<name> GIT_MAIL=<email> docker sandbox create -t portfolio:latest claude .
# docker sandbox run claude-portfolio
FROM docker/sandbox-templates:claude-code

USER root

RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    sqlite3 \
    tmux \
    curl \
    ripgrep \
    zsh \
    gh \
    #netcat-openbsd \
    vim \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install beads (bd) and dolt
RUN curl -fsSL https://raw.githubusercontent.com/steveyegge/beads/main/scripts/install.sh | bash
RUN curl -fsSL https://github.com/dolthub/dolt/releases/latest/download/install.sh | bash

# Enable pnpm
RUN corepack enable

# Set up directories
RUN mkdir -p /app && chown agent:agent /app 
WORKDIR /app

USER agent

SHELL ["/bin/bash", "-c"]
ENV PNPM_HOME="/home/agent/.pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV EDITOR=vim

COPY --chown=agent:agent . /app

RUN SHELL=bash pnpm setup && pnpm add -g typescript typescript-language-server @biomejs/biome

RUN pnpm install

ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["sleep", "infinity"]

